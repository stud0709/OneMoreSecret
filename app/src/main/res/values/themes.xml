<resources>
    <!-- Base application theme. -->
    <style name="Theme.OneMoreSecret" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_cyan_dark</item>
        <item name="colorPrimaryVariant">@color/primary_cyan</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/primary_cyan_dark</item>
        <item name="colorSecondaryVariant">@color/primary_cyan</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- Background and Surface Colors -->
        <item name="android:colorBackground">@color/bg_light</item>
        <item name="colorSurface">@color/bg_card_light</item>
        <item name="colorOnBackground">@color/text_primary_light</item>
        <item name="colorOnSurface">@color/text_primary_light</item>
        
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/bg_light</item>
        <item name="android:windowLightStatusBar">true</item>
        <!-- Customize your theme here. -->
    </style>


    <style name="Theme.OneMoreSecret.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.OneMoreSecret.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.OneMoreSecret.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>